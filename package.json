{
  "name": "@omgitsarnout/arniewaves-design-system",
  "version": "0.1.0",
  "description": "ArnieWaves design system — DIY, hand-crafted audio-tools aesthetic. React component library.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/arniewaves.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omgitsarnout/arniewaves-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "node scripts/build.mjs --serve",
    "build": "node scripts/build.mjs",
    "build:lib": "node scripts/build-lib.mjs",
    "prepublishOnly": "npm run build:lib",
    "start": "npm run dev"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
